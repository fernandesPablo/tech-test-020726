{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cache": {
    "StoryIdsTtl": "00:05:00",
    "StoryDetailsTtl": "00:10:00"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "LockTtl": "00:00:30",
    "LockRetryDelay": "00:00:00.200",
    "LockRetryCount": 10
  },
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com",
    "TimeoutSeconds": 30,
    "MaxConcurrentRequests": 10,
    "MaxN": 500
  },
  "Retry": {
    "MaxRetryCount": 3,
    "BaseDelayMs": 500
  },
  "CircuitBreaker": {
    "FailureThreshold": 5,
    "CoolDownSeconds": 60
  },
  "RateLimiter": {
    "PermitLimit": 30,
    "WindowSeconds": 60,
    "QueueLimit": 0
  }
}
